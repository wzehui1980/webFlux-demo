# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# All files
[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Java files
[*.java]
indent_size = 2

# XML files (including pom.xml)
[*.{xml,gradle}]
indent_size = 2

# SQL files
[*.sql]
charset = utf-8

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Properties files
[*.properties]
charset = utf-8

# Markdown files
[*.md]
trim_trailing_whitespace = false
